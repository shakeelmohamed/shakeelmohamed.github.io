mixin projectListing(project)
    div.block-project-listing
        a(href=project.url)
            //- img.portfolio-cover.block-project-cover(src=project.data.openGraphImage, alt="Cover image for " + project.data.title + " project", width="1200", height="630")
            +optimizedImage(project.data.openGraphImage, "Cover image for " + project.data.title + " project", "")
        div.block-project-copy
            div.block-project-title
                h2
                    a(href=project.url) #{project.data.title}
            //- TODO: need a max-width here so the lines aren't super long
            div.project-meta
                p.block-project-meta!= project.data.mediaLinks


mixin headernew()
    .mobile-only.mobileHeader
        .grid-2.flex-row.justify-between
            //- TODO: logo sizing is WIP, find a better way to match the height of 2 header lines
            div
                div.mobileBranding
                    a.logo-wrapper(href="/")
                        img(src="/img/Shakeel_Mohamed_wordmark.svg", alt="Shakeel Mohamed wordmark logo set in the Mindful Roman typeface which he designed")
                    br
                    strong
                        a(href="mailto:" + metadata.author.email, target="_blank") #{metadata.author.email}
            div.hamburgerIcon
                span.material-icons.text-2xl menu
        .menuItems
            h2
                a(href="/") Work
            h2
                a(href="/projects/thesis") Thesis
            h2
                a(href="/labyrinth") Experiments
            h2
                a(href="/about") About
            br
            h2
                a(href="mailto:" + metadata.author.email, target="_blank") #{metadata.author.email}
        hr.mobile-only
    div.newheader.sticky.top-0
        .grid-4
            div
                //- TODO: logo sizing is WIP, find a better way to match the height of 2 header lines
                .logo-wrapper
                    a(href="/")
                        img.logosvg(src="/img/Shakeel_Mohamed_wordmark.svg" alt="Shakeel Mohamed wordmark logo set in the Mindful Roman typeface which he designed")
            div.
            div
                div.pb-4
                    p
                        strong Strategic Brand Designer
                div
                    //- TODO: how can I avoid breaking between the icon and word?
                    //- TODO: can add a blog link here after grad + seeings 3-4 new posts
                    p
                        strong
                            a(href="/projects" class="mr-16")
                                span.material-icons.headerIcon public
                                | Work
                            | &nbsp;
                            a(href="/labyrinth")
                                span.material-icons.headerIcon swap_calls
                                | Experiments
                        
            div.deskright-mobileleft
                div.pb-4
                    p
                        strong
                            +myEmail()
                div
                    p
                        strong
                            a(href="/about") About
        hr.mb-2

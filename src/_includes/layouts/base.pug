mixin header()
    header.mobile-only.mobileHeader
        .mobile-header-row
            //- TODO: logo sizing is WIP, find a better way to match the height of 2 header lines
            div
                div.mobileBranding
                    a.logo-wrapper(href="/")
                        img(src="/img/Shakeel_Mohamed_wordmark.svg", alt="Shakeel Mohamed wordmark logo set in the Mindful Roman typeface which he designed")
                    br
                    strong
                        a(href="mailto:" + metadata.author.email, target="_blank") #{metadata.author.email}
            div.hamburgerIcon
                span.material-icons menu
        .menuItems
            h2
                a(href="/") Work
            h2
                a(href="/projects/thesis") Thesis
            h2
                a(href="/labyrinth") Experiments
            h2
                a(href="/about") About
            br
            h2
                a(href="mailto:" + metadata.author.email, target="_blank") #{metadata.author.email}
        hr.mobile-only
    .newheader.sticky.top-0
        .grid-4
            div
                //- TODO: logo sizing is WIP, find a better way to match the height of 2 header lines
                .logo-wrapper
                    a(href="/")
                        img.logosvg(src="/img/Shakeel_Mohamed_wordmark.svg" alt="Shakeel Mohamed wordmark logo set in the Mindful Roman typeface which he designed")
            div
            .col-start-3.col-end-5
                .pb-4.flex.justify-between.items-baseline
                    p
                        strong Strategic Brand Designer
                    p
                        strong
                            +myEmail()
                .flex.justify-between.items-baseline
                    p
                        strong
                            a(href="/projects") Work
                    p
                        strong
                            a(href="/labyrinth") Experiments
                    p
                        strong
                            a(href="/about") About
        hr.mb-2

//- TODO: bring back +mailingListForm()

mixin footer()
    hr
    footer.newfooter
        div
            br.mobile-only
            a.logo-wrapper(href="/")
                script document.write("&copy; " + new Date().getFullYear() + " Shakeel Mohamed.")
        div
            a(href=metadata.social.Instagram, target="_blank") Instagram
        div
            a(href=metadata.social.LinkedIn, target="_blank") LinkedIn
        div
            a(href="mailto:" + metadata.author.email, target="_blank")
                +myEmail()
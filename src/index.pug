---
description: Strategic brand designer in Los Angeles specializing in identity design, typography, and systems thinking. Available for freelance and full-time opportunities.
---

extends _includes/layouts/base.pug
include _includes/project_utils.pug

block content
    .grid-1
        div.py-4
            p.bigType
                //- | Strategic brand designer in Los Angeles specializing in identity design, typography, and systems thinking. Available for freelance and full&#8209;time&nbsp;opportunities.
                | Strategic brand designer in Los Angeles specializing in identity design, typography, and systems thinking. Available for freelance&nbsp;opportunities.
            div.h-4
            p.bigType
                span.material-icons.bigIcon arrow_right_alt
                | &nbsp;Ready to work together? Say&nbsp;
                br.mobile-only
                a(href="mailto:" + metadata.author.email, target="_blank") #{metadata.author.email}
                | .

    //- TODO: rework this to collections.home or something; goal is to have multiple blocks of content.
    //- could be projects, videos, bio, etc. -- MAYBE
    
    if collections.portfolio
        .grid-2
            each project in collections.portfolio
                - var isType = 0 !== project.fileSlug.indexOf("planetary") && project.data.media.includes("type design");
                unless isType
                    +projectListing(project)

        h2 Type Design
        hr.rule
        .grid-3
            p.caption I love love love typography! The rigor and systematic thought process of designing typefaces is something I enjoy and think about often. My love of typography began with a decade of computer programming experience.
        .grid-3
            each project in collections.portfolio
                - var isType = 0 !== project.fileSlug.indexOf("planetary") && project.data.media.includes("type design");
                if isType
                    +projectListing(project)